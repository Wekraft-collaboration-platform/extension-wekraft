# ─────────────────────────────────────────────────────────────────────────────
# GitPilot Extension — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — NEVER commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Your Convex deployment URL.
# Get it from: https://dashboard.convex.dev → your project → Settings → Deployment URL
# Format: https://<your-project-slug>.convex.cloud
CONVEX_DEPLOYMENT_URL=https://your-project.convex.cloud

# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# Enable verbose GitPilot logging in the VS Code Output panel.
# Set to "true" to turn on, leave blank or "false" to disable.
GITPILOT_DEBUG=false
