{
  "name": "gitpilot-bhanu",
  "displayName": "GitPilot: Push Intelligence",
  "icon": "media/logo.svg",
  "description": "AI-native platform for teaming up and shipping projects. GitHub-integrated push intelligence, project deadlines, and commit history tracking in your IDE. Works with VS Code and Cursor.",
  "version": "0.2.0",
  "publisher": "bhanupartap",
  "author": "bhanu",
  "license": "MIT",
  "galleryBanner": {
    "color": "#0c1119",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gitpilot/gitpilot-vscode"
  },
  "bugs": {
    "url": "https://github.com/gitpilot/gitpilot-vscode/issues"
  },
  "homepage": "https://wekraft.xyz",
  "keywords": [
    "github",
    "collaboration",
    "project-management",
    "git",
    "push-intelligence",
    "team",
    "shipping",
    "deadline",
    "commit-history"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitpilot.loginWithGitHub",
        "title": "GitPilot: Login with GitHub"
      },
      {
        "command": "gitpilot.installPrePushHook",
        "title": "GitPilot: Install Pre-Push Hook"
      },
      {
        "command": "gitpilot.runPrePushCheck",
        "title": "GitPilot: Run Pre-Push Check"
      },
      {
        "command": "gitpilot.refreshSidebar",
        "title": "GitPilot: Refresh Sidebar"
      },
      {
        "command": "gitpilot.syncNow",
        "title": "GitPilot: Sync Now"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitpilot",
          "title": "GitPilot",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "gitpilot": [
        {
          "id": "gitpilot.sidebar",
          "name": "Mission Control",
          "type": "webview",
          "icon": "media/activity-icon.svg",
          "visibility": "visible"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "watch:clean": "node --no-deprecation --no-warnings ./node_modules/typescript/bin/tsc -watch -p ./",
    "debug:clean": "node --no-deprecation --no-warnings ./dist/extension.js",
    "lint": "eslint src --ext ts",
    "test": "node --test dist/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "convex": "^1.0.0",
    "dotenv": "^16.6.1",
    "uuid": "^9.0.0"
  }
}
